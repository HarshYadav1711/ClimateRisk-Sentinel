# Copy to backend/.env — no paid APIs required.

DATABASE_URL=postgresql+psycopg://sentinel:sentinel@127.0.0.1:5432/climate_risk

# Optional: extra browser origins for CORS (comma-separated).
# CORS_ORIGINS=

# Optional: cap validation AOI size (km²). See Settings in app/config.py.
# MAX_AOI_AREA_KM2=500000

# Optional: cap raster analysis AOI size (km²). Above this, OSM metrics may still run.
# ANALYSIS_MAX_AOI_AREA_KM2=75000

# Optional: STAC / Overpass defaults (see app/config.py for full list).
# STAC_CATALOG_URL=https://planetarycomputer.microsoft.com/api/stac/v1
# Fixed datetime interval overrides rolling window; omit for `<today−lookback>/<today>` UTC.
# STAC_DATETIME_PRESET=2024-01-01/2025-12-31
# Rolling window length in days when STAC_DATETIME_PRESET is unset (default 365).
# STAC_LOOKBACK_DAYS=365
# OVERPASS_URL=https://overpass-api.de/api/interpreter

# Optional: in-process analysis caches + request ceiling (seconds). 0 = no timeout.
# ANALYSIS_INFRA_CACHE_TTL_SECONDS=300
# ANALYSIS_INFRA_CACHE_MAX_ENTRIES=128
# ANALYSIS_REPORT_CACHE_TTL_SECONDS=300
# ANALYSIS_REPORT_CACHE_MAX_ENTRIES=64
# ANALYSIS_REQUEST_TIMEOUT_SECONDS=300
