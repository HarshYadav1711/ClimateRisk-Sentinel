# Frontend (Vite) — optional local overrides
# Copy to frontend/.env.local (gitignored) or set in Vercel / Netlify project settings.

# Public origin of the FastAPI service (no trailing slash). Required when the UI is hosted
# separately from the API (e.g. Vercel + Render). Leave unset for local dev — the dev server
# proxies `/api` to the backend (see `vite.config.ts` and `VITE_DEV_PROXY_API`).
# VITE_API_BASE_URL=https://your-api.example.com

# Optional: where Vite should proxy `/api` during local development (default http://127.0.0.1:8000).
# VITE_DEV_PROXY_API=http://127.0.0.1:8000
